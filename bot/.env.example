# ============================================================
#  LitVM Auto Bridge Bot Configuration
# ============================================================

# Wallet private keys (3 wallets run in parallel)
WALLET_1_PRIVATE_KEY=0x...
WALLET_2_PRIVATE_KEY=0x...
WALLET_3_PRIVATE_KEY=0x...

# Bridge amount range (random between min and max, in ether)
BRIDGE_AMOUNT_MIN=0.011
BRIDGE_AMOUNT_MAX=0.1

# Delay settings (milliseconds)
# Time to wait for relayer to process (poll interval for balance check)
RELAYER_WAIT_POLL_MS=10000
# Max time to wait for relayer before giving up
RELAYER_WAIT_TIMEOUT_MS=300000
# Delay between routes within a cycle
DELAY_BETWEEN_ROUTES_MS=5000
# Delay between full loop cycles
DELAY_BETWEEN_LOOPS_MS=10000

# RPC URLs (comma-separated for fallback)
LITEFORGE_RPC_URLS=https://liteforge.rpc.caldera.xyz/http
SEPOLIA_RPC_URLS=https://ethereum-sepolia-rpc.publicnode.com,https://rpc.sepolia.org,https://sepolia.drpc.org,https://1rpc.io/sepolia
BASE_SEPOLIA_RPC_URLS=https://sepolia.base.org,https://base-sepolia-rpc.publicnode.com,https://base-sepolia.drpc.org

# Contract addresses
BRIDGE_VAULT_ADDRESS=0x9929ED0EdA9ecF57BDAB6423B4b12cDe3317196d
WRAPPED_ZKLTC_SEPOLIA_ADDRESS=0x4320BB234A76f94F9eeDD0E81968668C6d29c39f
WRAPPED_ZKLTC_BASE_SEPOLIA_ADDRESS=0xB378f0359815ECEC5Ae3c5aC4c49c12b70931688
