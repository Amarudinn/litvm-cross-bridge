# Relayer private key (must have ETH on both chains for gas)
RELAYER_PRIVATE_KEY=0x...

# RPC URLs
LITEFORGE_RPC_URL=https://liteforge.rpc.caldera.xyz/http
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Contract addresses (set after deployment)
BRIDGE_VAULT_ADDRESS=0x...
WRAPPED_ZKLTC_ADDRESS=0x...

# Chain configs
LITEFORGE_CHAIN_ID=4441
SEPOLIA_CHAIN_ID=11155111

# Relayer settings
POLL_INTERVAL_MS=5000
CONFIRMATION_BLOCKS=3
MAX_RETRIES=5

# Concurrency (parallel tx execution per chain)
MINT_CONCURRENCY=3
UNLOCK_CONCURRENCY=3

# Supabase (optional - for transaction indexing)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
